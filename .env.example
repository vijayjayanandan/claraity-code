# AI Coding Agent Configuration

# LLM Backend Configuration
LLM_BACKEND=ollama  # Options: ollama, openai
LLM_MODEL=codellama:7b-instruct  # Model name/path
LLM_HOST=http://localhost:11434  # Backend API endpoint
OPENAI_API_KEY=  # API key for OpenAI-compatible backends (Claude, Alibaba, etc.)
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TOP_P=0.95
LLM_TOP_K=40

# Context Window Settings
MAX_CONTEXT_TOKENS=4096  # Adjust based on your model
WORKING_MEMORY_TOKENS=2000
EPISODIC_MEMORY_TOKENS=1000
SYSTEM_PROMPT_TOKENS=300

# Code Analysis
ENABLE_AST_ANALYSIS=true
ENABLE_DEPENDENCY_GRAPH=true
SUPPORTED_LANGUAGES=python,javascript,typescript,java,go,rust,cpp

# Caching
ENABLE_CACHE=true
CACHE_BACKEND=memory  # Options: memory, redis, disk
CACHE_TTL=3600  # Seconds
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Session Management
SESSION_STORAGE=disk  # Options: disk, redis
SESSION_PATH=./data/sessions
SESSION_TIMEOUT=7200  # Seconds

# Logging
LOG_LEVEL=WARNING  # DEBUG, INFO, WARNING, ERROR, CRITICAL
DEBUG_MODE=false  # Set to true to enable tool loop debugging output
LOG_FILE=./logs/agent.log
LOG_FORMAT=json  # Options: json, text

# Observability (Langfuse - LLM Tracing & Cost Tracking)
LANGFUSE_ENABLED=false  # Enable Langfuse observability (set to true to activate)
LANGFUSE_PUBLIC_KEY=  # Get from Langfuse dashboard (Settings > API Keys)
LANGFUSE_SECRET_KEY=  # Get from Langfuse dashboard (Settings > API Keys)
LANGFUSE_HOST=http://localhost:3000  # Self-hosted URL or https://us.cloud.langfuse.com

# OpenTelemetry Configuration (required for Langfuse v3 OTEL-based SDK)
# For Langfuse Cloud US: https://us.cloud.langfuse.com/api/public/otel
# For Langfuse Cloud EU: https://cloud.langfuse.com/api/public/otel
# For self-hosted: http://localhost:3000/api/public/otel
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:3000/api/public/otel
# Generate auth header: echo -n "YOUR_PUBLIC_KEY:YOUR_SECRET_KEY" | base64
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic BASE64_ENCODED_CREDENTIALS

# Setup Instructions:
# 1. Self-hosted: docker compose up -d, then access http://localhost:3000
# 2. Cloud: Sign up at https://us.cloud.langfuse.com (US) or https://cloud.langfuse.com (EU)
# 3. Get API keys from Settings > API Keys
# 4. Generate Base64: echo -n "pk-lf-xxx:sk-lf-xxx" | base64
# 5. Set LANGFUSE_ENABLED=true

# Performance
MAX_PARALLEL_REQUESTS=4
REQUEST_TIMEOUT=180  # LLM read timeout in seconds (3 min recommended for large generations)
ENABLE_STREAMING=true

# Context Management (Claude Sonnet 4.5 supports 200K, extended beta supports 1M)
MAX_CONTEXT_TOKENS=200000  # Total context window (standard: 200K, extended: 1M)
RESERVED_OUTPUT_TOKENS=12000  # Reserved for LLM response generation
RESERVED_TOOL_SCHEMA_TOKENS=3000  # Estimated tokens for tool definitions
SAFETY_BUFFER_TOKENS=2000  # Safety margin to prevent overflow

# Context pressure thresholds (triggers compaction actions)
CONTEXT_YELLOW_THRESHOLD=0.60  # 60% - Log warning
CONTEXT_ORANGE_THRESHOLD=0.80  # 80% - Trigger light compaction
CONTEXT_RED_THRESHOLD=0.90  # 90% - Force aggressive compaction
OBSERVATION_MASK_AGE=15  # Mask tool observations older than N turns

# Security
RESTRICT_FILE_ACCESS=true
ALLOWED_DIRECTORIES=.  # Comma-separated paths
BLOCKED_EXTENSIONS=.env,.key,.pem,.p12  # Sensitive files
MAX_FILE_SIZE_MB=10

# Development
DEBUG=false
ENABLE_PROFILING=false
PROFILE_OUTPUT=./logs/profile.prof

# Web Search Configuration
TAVILY_API_KEY=          # Required for web_search tool. Get from https://tavily.com (free: 1000/month)
