# AI Coding Agent Configuration

# LLM Backend Configuration
LLM_BACKEND=ollama  # Options: ollama, vllm, localai, llamacpp
LLM_MODEL=codellama:7b-instruct  # Model name/path
LLM_HOST=http://localhost:11434  # Backend API endpoint
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TOP_P=0.95
LLM_TOP_K=40

# Context Window Settings
MAX_CONTEXT_TOKENS=4096  # Adjust based on your model
WORKING_MEMORY_TOKENS=2000
EPISODIC_MEMORY_TOKENS=1000
SYSTEM_PROMPT_TOKENS=300

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2  # Lightweight: 384 dimensions
# Alternative: BAAI/bge-small-en-v1.5 (384 dim), nomic-ai/nomic-embed-text-v1 (768 dim)

# Vector Database
VECTOR_DB=chromadb  # Options: chromadb, qdrant, milvus
VECTOR_DB_PATH=./data/embeddings
VECTOR_DB_COLLECTION=codebase

# Memory Configuration
ENABLE_EPISODIC_MEMORY=true
ENABLE_SEMANTIC_MEMORY=true
MEMORY_COMPRESSION_THRESHOLD=0.8  # Compress when 80% full
MEMORY_RELEVANCE_THRESHOLD=0.7  # Minimum similarity score

# RAG Settings
RAG_TOP_K=5  # Number of relevant chunks to retrieve
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_RERANK=true
RAG_HYBRID_SEARCH=true  # Combine keyword + semantic search
RAG_HYBRID_ALPHA=0.7  # Weight for semantic search (0-1)

# Code Analysis
ENABLE_AST_ANALYSIS=true
ENABLE_DEPENDENCY_GRAPH=true
SUPPORTED_LANGUAGES=python,javascript,typescript,java,go,rust,cpp

# Caching
ENABLE_CACHE=true
CACHE_BACKEND=memory  # Options: memory, redis, disk
CACHE_TTL=3600  # Seconds
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Session Management
SESSION_STORAGE=disk  # Options: disk, redis
SESSION_PATH=./data/sessions
SESSION_TIMEOUT=7200  # Seconds

# Logging
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR
LOG_FILE=./logs/agent.log
LOG_FORMAT=json  # Options: json, text

# Performance
MAX_PARALLEL_REQUESTS=4
REQUEST_TIMEOUT=30
ENABLE_STREAMING=true

# Security
RESTRICT_FILE_ACCESS=true
ALLOWED_DIRECTORIES=.  # Comma-separated paths
BLOCKED_EXTENSIONS=.env,.key,.pem,.p12  # Sensitive files
MAX_FILE_SIZE_MB=10

# Development
DEBUG=false
ENABLE_PROFILING=false
PROFILE_OUTPUT=./logs/profile.prof
